{
  "expo": {
    "name": "CodeFest2026",
    "slug": "CodeFest2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "codefest2026",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.CodeFest2026",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rocky uses your microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Rocky uses speech recognition to understand your voice commands.",
        "NSCalendarsUsageDescription": "Rocky saves events to your calendar.",
        "NSCalendarsWriteOnlyAccessUsageDescription": "Rocky saves events to your calendar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow RockyAI to add saved events to your calendar."
        }
      ],
      "@react-native-voice/voice"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
